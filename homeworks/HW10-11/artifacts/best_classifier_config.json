  },
  "optimizer": {
    "type": "Adam",
    "lr": 0.001
  },
  "training": {
    "criterion": "CrossEntropyLoss",
    "batch_size": 64,
    "max_epochs": 5,
    "early_stopping": false
  },
  "results": {
    "best_test_accuracy": 0.3826,
    "best_test_loss": 3.7864691287994385,
    "epochs_trained": 5
  }
